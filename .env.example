# Back4App — Core API (Settings → Security & Keys → App Keys)
VITE_PARSE_APP_ID=your_application_id
VITE_PARSE_JS_KEY=your_javascript_key

# Optional: defaults to Back4App Parse server
VITE_PARSE_SERVER_URL=https://parseapi.back4app.com

# ----------------------------
# Optional Node/Express API
# ----------------------------
# Keep these ONLY on the server (never in Vercel frontend env as VITE_*).
PARSE_APP_ID=your_application_id
PARSE_REST_API_KEY=your_rest_api_key
PARSE_SERVER_URL=https://parseapi.back4app.com

JWT_SECRET=replace_with_long_random_secret
CORS_ORIGIN=http://localhost:5173
